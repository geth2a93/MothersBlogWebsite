INSERT INTO book (id, title, synopsis, genre, book_image_url) VALUES
(1, 'Book One', 'A great first book.', 0, 'https://example.com/book1.jpg'),
(2, 'Book Two', 'Sequel to the first.', 1, 'https://example.com/book2.jpg');

INSERT INTO buy_links (id, links_url, book_id) VALUES
(1, 'https://amazon.com/book1', 1),
(2, 'https://barnesandnoble.com/book1', 1),
(3, 'https://amazon.com/book2', 2);


INSERT INTO reviews (id, link_url, name, title, content, rating, book_id) VALUES
(1, 'https://reviewsite.com/r1', 'John', 'Great read', 'Loved it a lot.', 5, 1),
(2, 'https://reviewsite.com/r2', 'Sarah', 'Not bad', 'Pretty decent book.', 4, 1),
(3, 'https://reviewsite.com/r3', 'Mike', 'Could be better', 'Had some issues.', 3, 2);


INSERT INTO subscribers (id, email, name) VALUES
(1, 'user1@example.com', 'Alice'),
(2, 'user2@example.com', NULL),
(3, 'user3@example.com', 'Bob');</sql><current_tab id="0"/></tab_sql></sqlb_project>

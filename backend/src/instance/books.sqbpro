-- =========================

INSERT INTO book (title, synopsis, genre, book_image_url, date_added)
VALUES

-- =========================
-- ROMANCE
-- =========================

(
'Letters Beneath the Rain',
'Lorem ipsum dolor sit amet, consectetur adipiscing elit. A heartfelt romance unfolds between two strangers exchanging anonymous letters during a storm-filled summer. As secrets surface and emotions deepen, both must decide whether love is worth risking the lives they carefully built for themselves.',
'Romance',
'/static/uploads/romance_book2.jpg',
'2026-04-08 13:25:00'
),

(
'The Ocean Between Us',
'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Two former lovers reunite years later while restoring a coastal inn threatened by financial ruin. Old memories, unresolved heartbreak, and unexpected second chances force them to confront the feelings they left behind.',
'Romance',
'/static/uploads/romance_book3.jpg',
'2026-04-05 17:40:00'
),

-- =========================
